# Copy this file to .env and fill in the values.
# (.env is gitignored and never committed.)

# MongoDB connection string (free tier: https://www.mongodb.com/atlas)
MONGO_URI=

# Free Gemini API key for the AI features (https://aistudio.google.com/)
GEMINI_API_KEY=

# Secret for signing login tokens — any long random string
JWT_SECRET=

# Frontend URL (used in password-reset links). For local dev leave as-is.
CLIENT_URL=http://localhost:3000

# OPTIONAL — to actually email password-reset links (Gmail app password).
# Leave blank to use demo mode (the reset link is shown on screen instead).
EMAIL_USER=
EMAIL_PASS=
